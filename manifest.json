{
  "manifest_version": 3,
  "name": "TabPulse",
  "version": "1.0.0",
  "description": "Auto-refresh any tab on a configurable interval with a live countdown.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "TabPulse",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["tabs", "alarms", "storage"],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
